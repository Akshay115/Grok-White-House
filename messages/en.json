      "nina": {
        "author": "Nina Shtaros",
        "date": "December 30",
        "text": "We've come back here as a family for the third time! The location is a dream — the airport is just 7 minutes away. Magical heated pools! The house itself is a masterpiece — stunning renovation and crystal cleanliness."
      },
      "vyacheslav": {
        "author": "Vyacheslav Artemyev",
        "date": "September 8",
        "text": "Beautiful, clean rooms with brand-new renovation. Snow-white fluffy towels and crisp linens. Two heated pools with crystal-clear water. Huge thanks to host Irina for the delicious breakfasts!"
      },
      "lada": {
        "author": "Lada",
        "date": "March 15",
        "text": "Rooms in Krasnaya Polyana are pricey, but here you can ski and stroll to the sea. We'll only come back here. The breakfasts are superb!"
      },
      "victoria": {
        "author": "Victoria L.",
        "date": "October 24",
        "text": "Excellent hotel. Clean rooms, great location, delicious breakfasts. Parking available. Very pleasant staff."
      }
    }
