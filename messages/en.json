  "about": {
    "eyebrow": "ABOUT US",
    "heading": "Where Architecture Meets Hospitality",
    "paragraphs": {
      "p1": "White House is a newly built guest house with designer renovation, where a crisp white aesthetic meets modern interiors. Crystal cleanliness, thoughtful details, and a sense of warmth create a truly premium atmosphere.",
      "p2": "The property sits at a road junction between Krasnaya Polyana mountain resorts and the Sirius Federal Territory. Adler Airport is 7 minutes away, Rosa Khutor 30 minutes, and Sirius beaches 10 minutes by car.",
      "p3": "Hosts Irina and Vladimir welcome every guest like close friends: personal attention, delicious breakfasts, and help with routes and excursions. Here, hospitality is not a service — it is a way of life."
    },
    "quote": {
      "text": "We've come back here as a family for the third time!",
      "attribution": "Nina Shtaros, guest"
    },
